# ============================================================
# Vision Board — 環境変数設定例
# Vercel デプロイ時はダッシュボードの Environment Variables に追加
# ============================================================

# Pexels API（写真検索）
# https://www.pexels.com/api/
# サーバー専用キー（推奨・Vercel対応）
PEXELS_API_KEY=your_pexels_api_key_here

# Replicate API（AI画像生成 FLUX.2-pro）
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# AI生成のロック解除合言葉
# 3回使い切ったときに入力するとカウントがリセットされる
AI_PASSPHRASE=enjoyfication

# HuggingFace（バックアップ用・任意）
# NEXT_PUBLIC_HF_TOKEN=your_hf_token_here
